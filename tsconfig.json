{
  "extends": "@tsconfig/node18/tsconfig.json",
  "compilerOptions": {
    "outDir": "./.homeybuild",
    "rootDir": ".",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "app.ts",
    "drivers/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".homeybuild"
  ]
}
