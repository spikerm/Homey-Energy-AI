{
  "id": "com.rexm.energyai",
  "version": "0.6.0",
  "compatibility": ">=12.0.0",
  "sdk": 3,
  "name": { "en": "Homey Energy AI", "nl": "Homey Energy AI" },
  "description": {
    "en": "Local energy analysis and advisory automation for Homey Pro.",
    "nl": "Lokale energieanalyse en adviseringsautomatisering voor Homey Pro."
  },
  "category": ["energy"],
  "brandColor": "#1B5E20",
  "author": { "name": "Rex Markesteijn" },
  "support": "https://github.com/spikerm/Homey-Energy-AI/issues",
  "source": "https://github.com/spikerm/Homey-Energy-AI",
  "platforms": ["local"],
  "permissions": ["homey:manager:api"],
  "capabilities": {
    "energy_ai_mode": {
      "type": "enum",
      "title": { "en": "AI mode", "nl": "AI-modus" },
      "values": [
        { "id": "observe", "title": { "en": "Observe", "nl": "Observeren" } },
        { "id": "advice", "title": { "en": "Advice", "nl": "Advies" } }
      ],
      "getable": true,
      "setable": false,
      "uiComponent": "picker",
      "icon": "/assets/icons/energy.svg"
    },
    "energy_ai_score": { "type": "number", "title": { "en": "Confidence", "nl": "Zekerheid" }, "units": "%", "min": 0, "max": 100, "decimals": 0, "getable": true, "setable": false, "uiComponent": "sensor", "icon": "/assets/icons/energy.svg" },
    "energy_ai_energy_score": { "type": "number", "title": { "en": "Energy score", "nl": "Energiescore" }, "units": "/100", "min": 0, "max": 100, "decimals": 0, "getable": true, "setable": false, "insights": true, "uiComponent": "sensor", "icon": "/assets/icons/energy.svg" },
    "energy_ai_self_consumption": { "type": "number", "title": { "en": "Solar self-consumption", "nl": "Eigen gebruik zon" }, "units": "%", "min": 0, "max": 100, "decimals": 0, "getable": true, "setable": false, "insights": true, "uiComponent": "sensor", "icon": "/assets/icons/solar.svg" },
    "energy_ai_advice": { "type": "string", "title": { "en": "Current advice", "nl": "Huidig advies" }, "getable": true, "setable": false, "uiComponent": "sensor", "icon": "/assets/icons/energy.svg" },
    "energy_ai_savings_today": { "type": "number", "title": { "en": "Estimated savings today", "nl": "Besparing vandaag" }, "units": "€", "decimals": 2, "getable": true, "setable": false, "uiComponent": "sensor", "icon": "/assets/icons/energy.svg" },
    "energy_ai_grid_power": { "type": "number", "title": { "en": "Grid power", "nl": "Netvermogen" }, "units": "W", "decimals": 0, "getable": true, "setable": false, "insights": true, "uiComponent": "sensor", "icon": "/assets/icons/energy.svg" },
    "energy_ai_consumption_power": { "type": "number", "title": { "en": "Home consumption", "nl": "Woningverbruik" }, "units": "W", "min": 0, "decimals": 0, "getable": true, "setable": false, "insights": true, "uiComponent": "sensor", "icon": "/assets/icons/energy.svg" },
    "energy_ai_solar_power": { "type": "number", "title": { "en": "Solar production", "nl": "Zonneproductie" }, "units": "W", "min": 0, "decimals": 0, "getable": true, "setable": false, "insights": true, "uiComponent": "sensor", "icon": "/assets/icons/solar.svg" },
    "energy_ai_battery_power": { "type": "number", "title": { "en": "Battery power", "nl": "Batterijvermogen" }, "units": "W", "decimals": 0, "getable": true, "setable": false, "insights": true, "uiComponent": "sensor", "icon": "/assets/icons/battery.svg" },
    "energy_ai_ev_power": { "type": "number", "title": { "en": "EV charging power", "nl": "EV-laadvermogen" }, "units": "W", "min": 0, "decimals": 0, "getable": true, "setable": false, "insights": true, "uiComponent": "sensor", "icon": "/assets/icons/ev.svg" },
    "energy_ai_battery_advice": { "type": "string", "title": { "en": "Battery advice", "nl": "Batterijadvies" }, "getable": true, "setable": false, "uiComponent": "sensor", "icon": "/assets/icons/battery.svg" },
    "energy_ai_ev_advice": { "type": "string", "title": { "en": "EV advice", "nl": "EV-advies" }, "getable": true, "setable": false, "uiComponent": "sensor", "icon": "/assets/icons/ev.svg" },
    "energy_ai_data_status": { "type": "string", "title": { "en": "Data status", "nl": "Datastatus" }, "getable": true, "setable": false, "uiComponent": "sensor", "icon": "/assets/icons/energy.svg" },
    "energy_ai_last_update": { "type": "string", "title": { "en": "Last update", "nl": "Laatste update" }, "getable": true, "setable": false, "uiComponent": "sensor", "icon": "/assets/icons/energy.svg" }
  },
  "drivers": [
    {
      "id": "energy_ai",
      "name": { "en": "Energy AI", "nl": "Energy AI" },
      "class": "sensor",
      "capabilities": [
        "energy_ai_mode",
        "energy_ai_score",
        "energy_ai_energy_score",
        "energy_ai_self_consumption",
        "energy_ai_advice",
        "energy_ai_savings_today",
        "energy_ai_grid_power",
        "energy_ai_consumption_power",
        "energy_ai_solar_power",
        "energy_ai_battery_power",
        "energy_ai_ev_power",
        "energy_ai_battery_advice",
        "energy_ai_ev_advice",
        "energy_ai_data_status",
        "energy_ai_last_update"
      ],
      "settings": [
        {
          "id": "ev_charging_threshold",
          "type": "number",
          "label": { "en": "Minimum EV charging power", "nl": "Minimaal EV-laadvermogen" },
          "hint": { "en": "Below this power the car is considered not charging.", "nl": "Onder dit vermogen wordt de auto als niet-ladend beschouwd." },
          "value": 250,
          "min": 0,
          "max": 5000,
          "step": 10,
          "units": { "en": "W", "nl": "W" }
        },
        {
          "id": "battery_active_threshold",
          "type": "number",
          "label": { "en": "Battery active threshold", "nl": "Drempel actief batterijvermogen" },
          "hint": { "en": "Below this absolute power the battery is considered on standby.", "nl": "Onder dit absolute vermogen wordt de batterij als stand-by beschouwd." },
          "value": 100,
          "min": 0,
          "max": 2000,
          "step": 10,
          "units": { "en": "W", "nl": "W" }
        },
        {
          "id": "grid_deadband_threshold",
          "type": "number",
          "label": { "en": "Grid balance deadband", "nl": "Dode band netbalans" },
          "hint": { "en": "Grid values within this range are shown as zero.", "nl": "Netwaarden binnen deze grens worden als nul weergegeven." },
          "value": 100,
          "min": 0,
          "max": 1000,
          "step": 10,
          "units": { "en": "W", "nl": "W" }
        },
        {
          "id": "high_import_threshold",
          "type": "number",
          "label": { "en": "High grid import", "nl": "Hoge netafname" },
          "hint": { "en": "Above this power a high-import warning is generated.", "nl": "Boven dit vermogen wordt een waarschuwing voor hoge netafname gegeven." },
          "value": 2500,
          "min": 250,
          "max": 25000,
          "step": 100,
          "units": { "en": "W", "nl": "W" }
        },
        {
          "id": "solar_surplus_threshold",
          "type": "number",
          "label": { "en": "Solar surplus threshold", "nl": "Drempel zonne-overschot" },
          "hint": { "en": "Minimum solar production for solar-surplus advice.", "nl": "Minimale zonneproductie voor advies over zonne-overschot." },
          "value": 500,
          "min": 0,
          "max": 10000,
          "step": 100,
          "units": { "en": "W", "nl": "W" }
        },
        {
          "id": "refresh_interval_seconds",
          "type": "number",
          "label": { "en": "Refresh interval", "nl": "Verversingsinterval" },
          "hint": { "en": "How often energy values are refreshed. Minimum 10 seconds.", "nl": "Hoe vaak de energiewaarden worden vernieuwd. Minimaal 10 seconden." },
          "value": 60,
          "min": 10,
          "max": 600,
          "step": 10,
          "units": { "en": "s", "nl": "s" }
        }
      ],
      "pair": [
        { "id": "list_devices", "template": "list_devices", "navigation": { "next": "add_devices" } },
        { "id": "add_devices", "template": "add_devices" }
      ]
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "advice_changed",
        "title": { "en": "The Energy AI advice changed", "nl": "Het Energy AI-advies is gewijzigd" },
        "args": [{ "name": "device", "type": "device", "filter": "driver_id=energy_ai" }],
        "tokens": [
          { "name": "advice", "type": "string", "title": { "en": "Advice", "nl": "Advies" }, "example": { "en": "Use available solar power", "nl": "Gebruik het beschikbare zonnevermogen" } },
          { "name": "confidence", "type": "number", "title": { "en": "Confidence", "nl": "Zekerheid" }, "example": 80 }
        ]
      }
    ],
    "actions": [
      { "id": "recalculate_advice", "title": { "en": "Recalculate the Energy AI advice", "nl": "Bereken het Energy AI-advies opnieuw" } }
    ]
  }
}
